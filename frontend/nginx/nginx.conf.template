server {
    listen 80;
    absolute_redirect off;
    charset utf-8;
    charset_types text/plain text/css application/javascript application/json application/xml text/xml;
    set_real_ip_from 127.0.0.1;
    set_real_ip_from 172.16.0.0/12;
    real_ip_header X-Forwarded-For;
    real_ip_recursive on;
    resolver 127.0.0.11 ipv6=off valid=30s;
    set $api_url $API_URL;

    access_log /dev/stdout combined;

    location ~* ^/(?:\.env(?:[._-][^/]*)?|env|(?:config|app|src|backend|api)/\.env|\.docker\.env)$ {
        access_log /var/log/nginx/security-scan.log combined;
        return 403;
    }

    location ~* ^/(?:\.git(?:/config|-credentials)?|\.npmrc|\.pypirc|\.yarnrc(?:\.yml)?|\.github/workflows/[^/]+\.ya?ml|Jenkinsfile|\.gitlab-ci\.yml)$ {
        access_log /var/log/nginx/security-scan.log combined;
        return 403;
    }

    location ~* ^/(?:wp-json/gravitysmtp(?:/.*)?|(?:wp-)?config\.php(?:[._-](?:bak|backup|old|save|swp|txt))?|settings\.php|(?:config|application|docker-compose|amplify)\.ya?ml|application(?:-production)?\.properties|Dockerfile|web\.config|(?:local_)?settings\.py|settings/production\.py|config/(?:database|secrets|application)\.ya?ml|(?:appsettings(?:\.(?:Development|Production))?|local\.settings|config|config/(?:production|development))\.json|(?:next|nuxt|vite)\.config\.js|firebase\.json|\.firebase/hosting\.json|composer\.json)$ {
        access_log /var/log/nginx/security-scan.log combined;
        return 403;
    }

    location ~* ^/(?:logs|storage/logs|var/log)/(?:error|application|laravel|app)\.log$ {
        access_log /var/log/nginx/security-scan.log combined;
        return 403;
    }

    location ~* ^/(?:database|dump|backup|db)\.sql$ {
        access_log /var/log/nginx/security-scan.log combined;
        return 403;
    }

    location = /.well-known/openapi.json {
        proxy_pass $api_url/docs/openapi.json;
        proxy_hide_header Content-Type;
        add_header Content-Type "application/json; charset=utf-8" always;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /metrics {
        return 404;
    }

    location ~ ^/(api|docs|metrics) {
        proxy_pass $api_url;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /controlloDDNS {
        return 301 https://$host/controllo-ddns/;
    }

    location ^~ /controlloDDNS/ {
        return 301 https://$host/controllo-ddns/;
    }

    location = /controlloMODEM {
        return 301 https://$host/controllo-modem/;
    }

    location ^~ /controlloMODEM/ {
        return 301 https://$host/controllo-modem/;
    }

    location = /controllo-ddns {
        return 301 https://$host/controllo-ddns/;
    }

    location = /controllo-modem {
        return 301 https://$host/controllo-modem/;
    }

    location ^~ /controllo-ddns/ {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /controllo-ddns/index.html =404;
    }

    location ^~ /controllo-modem/ {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /controllo-modem/index.html =404;
    }

    location ~ ^/(come-verificare-se-una-porta-e-aperta|test-port-forwarding|porte-tcp-comuni|porte-pericolose-da-aprire|ip-pubblico-nat-cgnat|perche-una-porta-risulta-chiusa|usare-controlloporte-con-chatgpt-claude)$ {
        return 301 https://$host$uri/;
    }

    location ~* ^/fonts/.*\.(ttf|woff|woff2|otf)$ {
        root /usr/share/nginx/html;
        add_header Cache-Control "public, max-age=2592000" always;
        try_files $uri =404;
    }

    location ~* \.(css|js|png|svg|ico|webmanifest|txt|xml|json|ttf|woff|woff2)$ {
        root /usr/share/nginx/html;
        try_files $uri =404;
    }

    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html =404;
    }
}
