{
    "name": "controlloporte.it",
    "version": "4.0.1",
    "description": "Single page site for controlloporte.it",
    "homepage": "https://github.com/impulso/controlloporte.it#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/impulso/controlloporte.it.git"
    },
    "author": "Impulso.it",
    "license": "MIT",
    "engines": {
        "node": ">=23",
        "npm": ">=10"
    },
    "bugs": {
        "url": "https://github.com/impulso/controlloporte.it/issues"
    },
    "scripts": {
        "dev": "API_URL=${API_URL:-http://api:8000} DEFAULT_HOST=${DEFAULT_HOST} DEFAULT_PORT=${DEFAULT_PORT} NODE_ENV=development webpack serve --history-api-fallback",
        "build": "DEFAULT_HOST=${DEFAULT_HOST} DEFAULT_PORT=${DEFAULT_PORT} NODE_ENV=production webpack build",
        "lint": "eslint src",
        "lint:fix": "npm run lint -- --fix",
        "prettier": "prettier src --check",
        "prettier:fix": "npm run prettier -- --write",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "copy-webpack-plugin": "^13.0.1",
        "css-loader": "^7.1.4",
        "css-minimizer-webpack-plugin": "^7.0.2",
        "eslint": "^10.0.2",
        "globals": "^17.6.0",
        "html-webpack-plugin": "^5.6.6",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "mini-css-extract-plugin": "^2.10.0",
        "prettier": "^3.8.1",
        "uglifyjs-webpack-plugin": "^2.2.0",
        "webpack": "^5.105.4",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2"
    }
}
